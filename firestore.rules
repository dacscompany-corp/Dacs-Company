rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc)
        ? get(userDoc).data.get('role', '')
        : '';
    }

    function isOwner() {
      return isAuthenticated() && getUserRole() == 'owner';
    }

    function isWorker() {
      return isAuthenticated() && (getUserRole() == 'worker' || getUserRole() == 'teamLeader');
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() == 'staff';
    }


    // Returns the ownerUid stored in the staff's user doc (for shared data access)
    function staffOwnerUid() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ownerUid', '');
    }

    function canAccessData(docUserId) {
      return isAuthenticated() && (
        request.auth.uid == docUserId ||
        (isStaff() && staffOwnerUid() == docUserId)
      );
    }

    // ═══════════════════════════════════════════════════════════════════
    // EXISTING COLLECTIONS (Building Design Website)
    // ═══════════════════════════════════════════════════════════════════

    match /appointments/{appointmentId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    match /testimonials/{testimonialId} {
      allow create: if true;
      allow read: if isAuthenticated()
                  || (resource.data.status == 'approved' && resource.data.rating >= 4);
      allow update, delete: if isAuthenticated();
    }

    match /stats/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && !('role' in request.resource.data);
      allow update: if isAuthenticated()
                    && request.auth.uid == userId
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /folders/{folderId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      // Clients can read folders where their email matches the assigned clientEmail
      allow read: if isAuthenticated()
                  && resource.data.get('clientEmail', '') != ''
                  && request.auth.token.email == resource.data.clientEmail;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    match /projects/{projectId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      // Clients can read projects where the parent folder has their email as clientEmail
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/folders/$(resource.data.folderId)).data.get('clientEmail', '') != ''
                  && request.auth.token.email == get(/databases/$(database)/documents/folders/$(resource.data.folderId)).data.clientEmail;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    // Helper: allows owner to write own data, or staff to write with owner's userId
    function canWriteData(docUserId) {
      return isAuthenticated() && (
        request.auth.uid == docUserId ||
        (isStaff() && staffOwnerUid() == docUserId)
      );
    }

    match /expenses/{expenseId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      allow create: if canWriteData(request.resource.data.userId);
    }

    match /payroll/{payrollId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      allow create: if canWriteData(request.resource.data.userId);
    }

    match /categories/{categoryId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      allow create: if canWriteData(request.resource.data.userId);
    }

    match /overheadExpenses/{expenseId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      allow create: if canWriteData(request.resource.data.userId);
    }

    // ═══════════════════════════════════════════════════════════════════
    // CONSTRUCTION MANAGEMENT COLLECTIONS
    // ═══════════════════════════════════════════════════════════════════

    match /requests/{requestId} {
      allow read: if isOwner() || isWorker();

      // ✅ FIXED: Added || isOwner() so owner role can also create requests
      allow create: if (isWorker() || isOwner())
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.status == 'pending';

      allow update: if isWorker()
        && resource.data.requestedBy == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && request.resource.data.requestedBy == resource.data.requestedBy;

      allow update: if isOwner();

      allow delete: if isOwner();
    }

    match /batches/{batchId} {
      allow read: if isOwner() || isWorker();
      allow create, update: if isOwner();
      allow delete: if isOwner();
    }

    match /inventory/{itemId} {
      allow read, create, update, delete: if isOwner();
    }

    match /notifications/{userId}/items/{notifId} {
      allow read, create, update, delete: if isAuthenticated()
                                          && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════════════════════════════
    // BOQ ACCOMPLISHMENT REPORT COLLECTION
    // ═══════════════════════════════════════════════════════════════════

    match /boqTemplates/{templateId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════
    // CLIENT PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════════════

    match /settings/{settingId} {
      allow read, write: if isOwner() || isStaff();
    }

    // Clients need to read the payment QR code to submit payments
    match /settings/paymentQR {
      allow read: if isAuthenticated();
    }

    match /invoices/{invoiceId} {
      allow read, update, delete: if canAccessData(resource.data.userId);
      allow create: if canWriteData(request.resource.data.userId);
      // Clients can read their own invoices (match by email or uid)
      allow read: if isAuthenticated() && (
        resource.data.clientEmail == request.auth.token.email ||
        resource.data.clientUid   == request.auth.uid
      );
    }

    // Client user profiles — each client can only read/write their own doc
    // Owner/staff can list all clients
    match /clientUsers/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read, write: if isOwner() || isStaff();
    }

    match /boqDocuments/{boqId} {
      // Owner/staff can list all (needed for client accounts page)
      allow read, update, delete: if isOwner() || isStaff();
      allow read, update, delete: if canAccessData(resource.data.userId);
      // Clients read BOQ docs where their email matches the assigned clientEmail
      allow read: if isAuthenticated()
                  && request.auth.token.email == resource.data.clientEmail;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    match /paymentRequests/{requestId} {
      // Owner/staff can do everything (including unfiltered list queries)
      allow read, create, update, delete: if isOwner() || isStaff();
      allow read, create, update, delete: if canAccessData(resource.data.userId);
      allow create: if canWriteData(request.resource.data.userId);

      // Clients can read their own payment requests
      allow read: if isAuthenticated()
                  && request.auth.token.email == resource.data.clientEmail;

      // Clients can self-initiate a payment request (must set their own email/uid and status=submitted)
      allow create: if isAuthenticated()
                    && request.auth.token.email == request.resource.data.clientEmail
                    && request.auth.uid          == request.resource.data.clientUid
                    && request.resource.data.status == 'submitted';

      // Clients can update their own requests for allowed status transitions
      allow update: if isAuthenticated()
                    && request.auth.token.email == resource.data.clientEmail
                    && (
                      // Request partial approval: pending → partial_pending
                      (resource.data.status == 'pending'
                        && request.resource.data.status == 'partial_pending')
                      // Cancel partial request: partial_pending → pending
                      || (resource.data.status == 'partial_pending'
                        && request.resource.data.status == 'pending')
                      // Submit payment: pending or partial_approved → submitted
                      || ((resource.data.status == 'pending' || resource.data.status == 'partial_approved')
                        && request.resource.data.status == 'submitted')
                    );
    }
  }
}
