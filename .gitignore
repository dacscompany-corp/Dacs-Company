# ── Ignore everything by default ──────────────────────────
*

# ── Allow folders ──────────────────────────────────────────
!*/

# ── Web project files to include ───────────────────────────
!*.html
!*.css
!*.js
!*.json
!*.md
!*.rules
!.gitignore

# ── Exclude generated/build folders ────────────────────────
node_modules/
build/
.gradle/
gradle/
app/
assets/

# ── Exclude generated files ─────────────────────────────────
sw.js
package.json
package-lock.json
*.apk
*.aab
*.idsig
*.keystore
*.txt
gradlew
gradlew.bat
